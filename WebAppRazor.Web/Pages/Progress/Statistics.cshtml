@page
@model WebAppRazor.Web.Pages.Progress.StatisticsModel
@{
    ViewData["Title"] = "Thống Kê Tổng Quan";
}

<style>
    /* Section headers */
    .section-title { font-weight: 700; color: #343a40; margin-bottom: 1rem; border-left: 4px solid #0d6efd; padding-left: 10px; }
    
    /* Heatmap CSS Grid */
    .heatmap-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(18px, 1fr));
        gap: 4px;
        margin-top: 10px;
    }
    .heatmap-cell {
        width: 18px;
        height: 18px;
        border-radius: 4px;
        background-color: #ebedf0; /* 0 = not completed */
        position: relative;
    }
    .heatmap-cell[data-status="1"] { background-color: #9be9a8; } /* 1 = partially completed */
    .heatmap-cell[data-status="2"] { background-color: #40c463; } /* 2 = mostly/fully completed */
    
    /* Heatmap Tooltip */
    .heatmap-cell:hover::after {
        content: attr(title);
        position: absolute;
        bottom: 150%; left: 50%;
        transform: translateX(-50%);
        background: #24292e; color: #fff;
        padding: 4px 8px; border-radius: 4px;
        font-size: 12px; white-space: nowrap;
        z-index: 10;
    }
</style>

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h2><i class="fas fa-layer-group text-primary"></i> Đánh Giá Nâng Cao</h2>
        <div class="d-flex align-items-center gap-2">
            <form method="post" asp-page-handler="SeedData" class="d-inline-block">
                <button class="btn btn-outline-success btn-sm" type="submit" onclick="return confirm('Tạo 30 ngày dữ liệu mẫu để thử nghiệm biểu đồ? Quá trình này không thể hoàn tác.')">
                    <i class="fas fa-magic me-1"></i> Đổ Dữ Liệu Mẫu
                </button>
            </form>
            <form method="get" class="d-flex align-items-center gap-2">
                <span class="form-label mb-0 fw-bold me-2">Thời gian:</span>
                <div class="btn-group shadow-sm" role="group">
                    <button type="submit" name="FilterType" value="Month" class="btn btn-sm @(Model.FilterType == "Month" ? "btn-primary" : "btn-outline-primary")">📅 Tháng</button>
                    <button type="submit" name="FilterType" value="Quarter" class="btn btn-sm @(Model.FilterType == "Quarter" ? "btn-primary" : "btn-outline-primary")">📊 Quý</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Dashboard == null)
    {
        <div class="alert alert-info">Unable to load dashboard data.</div>
    }
    else
    {
        <!-- Section 1: Health -->
        <h4 class="section-title mt-4">1. Health</h4>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card shadow-sm h-100 border-0 text-center p-3 bg-light">
                    <div class="row h-100 align-items-center">
                        <div class="col-12 mb-3 border-bottom pb-3">
                            <h5 class="text-muted mb-2">Chỉ số BMI</h5>
                            <div class="display-4 fw-bold text-primary mb-2">@Model.Dashboard.CurrentBMI</div>
                            <span class="badge rounded-pill bg-@(Model.Dashboard.BMIStatus == "Bình thường" ? "success" : "warning") fs-6 px-3 py-2">
                                @Model.Dashboard.BMIStatus
                            </span>
                        </div>
                        <div class="col-6 border-end">
                            <p class="text-muted mb-0 small">BMR</p>
                            <strong class="fs-5">@Model.Dashboard.CurrentBMR</strong><br/><small class="text-muted">kcal</small>
                        </div>
                        <div class="col-6">
                            <p class="text-muted mb-0 small">TDEE</p>
                            <strong class="fs-5">@Model.Dashboard.CurrentTDEE</strong><br/><small class="text-muted">kcal</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-body">
                        <h6 class="card-title text-primary"><i class="fas fa-chart-line"></i> Trọng lượng (Weight - kg)</h6>
                        <div style="position: relative; height: 180px;">
                            <canvas id="weightHistoryChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Section 2: Calories Today & Section 3: Nutrition Today -->
        <div class="row g-4 mt-2">
            <div class="col-md-8">
                <h4 class="section-title">2. Calories Target</h4>
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-body">
                        <div class="mb-4">
                            @{ 
                                double calProgress = Model.Dashboard.CalorieTargetToday > 0 ? (Model.Dashboard.CaloriesConsumedToday / Model.Dashboard.CalorieTargetToday) * 100 : 0;
                                double barWidth = calProgress > 100 ? 100 : calProgress;
                                string barColor = calProgress > 100 ? "bg-danger" : "bg-warning";
                            }
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-bold">Hôm nay (@Model.Dashboard.CaloriesConsumedToday / @Model.Dashboard.CalorieTargetToday kcal)</span>
                            </div>
                            <div class="progress" style="height: 25px;">
                                <div class="progress-bar progress-bar-striped progress-bar-animated @barColor text-dark fw-bold" 
                                     role="progressbar" style="width: @Math.Round(barWidth, 1)%;" aria-valuenow="@Math.Round(barWidth, 1)" aria-valuemin="0" aria-valuemax="100">
                                    @Math.Round(calProgress, 1)%
                                </div>
                            </div>
                        </div>
                        <h6 class="text-muted"><i class="fas fa-calendar-alt"></i> 7 Ngày Gần Nhất</h6>
                        <div style="position: relative; height: 200px;">
                            <canvas id="caloriesLast7DaysChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section 3: Nutrition Today -->
            <div class="col-md-4">
                <h4 class="section-title">3. Nutrition (Today) <span class="badge bg-secondary ms-2" style="font-size: 0.6em; vertical-align: middle;">Nâng cao</span></h4>
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-body d-flex flex-column align-items-center justify-content-center">
                        <div style="position: relative; height: 180px; width: 100%;">
                            <canvas id="nutritionDonutChart"></canvas>
                        </div>
                        <div class="d-flex w-100 justify-content-around mt-3 text-center">
                            <div><strong class="text-danger">Protein</strong><br/>@Model.Dashboard.ProteinToday g</div>
                            <div><strong class="text-primary">Carbs</strong><br/>@Model.Dashboard.CarbsToday g</div>
                            <div><strong class="text-warning">Fat</strong><br/>@Model.Dashboard.FatToday g</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- AI Insight -->
        <div class="alert alert-info py-3 mt-4 mb-4 shadow-sm border-0 bg-white" style="border-left: 4px solid #0dcaf0 !important;">
            <div class="d-flex align-items-center">
                <div class="fs-4 me-3 text-info"><i class="fas fa-robot"></i></div>
                <div>
                    <strong class="text-dark">AI Insight:</strong> 
                    <span class="text-muted ms-1">@Model.Dashboard.WeightTrendText</span>
                </div>
            </div>
        </div>

        <!-- Section 4: Progress Monthly/Quarterly -->
        <h4 class="section-title">4. Progress (@Model.FilterType)</h4>
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <h6 class="text-info"><i class="fas fa-chart-area"></i> Tiến độ chi tiết</h6>
                <div style="position: relative; height: 250px;">
                    <canvas id="progressChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Section 5: Habit Heatmap -->
        <h4 class="section-title mt-4">5. Habit Tracking (Last 90 Days) <span class="badge bg-secondary ms-2" style="font-size: 0.6em; vertical-align: middle;">Nâng cao</span></h4>
        <div class="card shadow-sm border-0 bg-white">
            <div class="card-body">
                <p class="text-muted small mb-2"><i class="fas fa-fire text-danger"></i> Dấu chấm xanh đại diện cho ngày mà bạn hoàn thành tốt các mục tiêu bữa ăn.</p>
                <div class="heatmap-grid" style="display: flex; flex-wrap: wrap;">
                    @foreach (var day in Model.Dashboard.HabitHeatmap)
                    {
                        string statusText = day.Count == 0 ? "Chưa hoàn thành" : day.Count == 1 ? "Hoàn thành một phần" : "Hoàn thành tốt";
                        <div class="heatmap-cell" data-status="@day.Count" title="@day.DateString: @statusText"></div>
                    }
                </div>
                <!-- Legend -->
                <div class="d-flex align-items-center mt-3 small text-muted">
                    <span class="me-2">Less</span>
                    <div class="heatmap-cell mx-1" data-status="0"></div>
                    <div class="heatmap-cell mx-1" data-status="1"></div>
                    <div class="heatmap-cell mx-1" data-status="2"></div>
                    <span class="ms-2">More</span>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            
            const commonOptions = {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } }
            };

            // 1. Weight History Line Chart
            const wCtx = document.getElementById('weightHistoryChart');
            if(wCtx) {
                new Chart(wCtx.getContext('2d'), {
                    type: 'line',
                    data: {
                        labels: @Html.Raw(Model.ChartLabelsWeightHistory),
                        datasets: [{
                            label: 'Weight (kg)',
                            data: @Html.Raw(Model.ChartDataWeightHistory),
                            borderColor: '#0d6efd',
                            backgroundColor: 'rgba(13, 110, 253, 0.1)',
                            borderWidth: 2,
                            fill: true,
                            tension: 0.4
                        }]
                    },
                    options: commonOptions
                });
            }

            // 2. Calories 7 Days Bar Chart
            const calCtx = document.getElementById('caloriesLast7DaysChart');
            if(calCtx) {
                new Chart(calCtx.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: @Html.Raw(Model.ChartLabelsCalories7Days),
                        datasets: [{
                            label: 'Calories (kcal)',
                            data: @Html.Raw(Model.ChartDataCalories7Days),
                            backgroundColor: '#ffc107',
                            borderRadius: 4
                        }]
                    },
                    options: commonOptions
                });
            }

            // 3. Nutrition Donut Chart
            const nutCtx = document.getElementById('nutritionDonutChart');
            if(nutCtx) {
                new Chart(nutCtx.getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: ['Protein', 'Carbs', 'Fat'],
                        datasets: [{
                            data: @Html.Raw(Model.ChartDataNutrition),
                            backgroundColor: ['#dc3545', '#0d6efd', '#ffc107'],
                            borderWidth: 0,
                            hoverOffset: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        },
                        cutout: '70%'
                    }
                });
            }

            // 4. Progress Line Chart
            const progCtx = document.getElementById('progressChart');
            if(progCtx) {
                new Chart(progCtx.getContext('2d'), {
                    type: 'line',
                    data: {
                        labels: @Html.Raw(Model.ChartLabelsProgress),
                        datasets: [{
                            label: 'Tiến độ',
                            data: @Html.Raw(Model.ChartDataProgress),
                            borderColor: '#0dcaf0',
                            backgroundColor: 'rgba(13, 202, 240, 0.2)',
                            borderWidth: 2,
                            fill: true,
                            tension: 0.2
                        }]
                    },
                    options: commonOptions
                });
            }
            
        });
    </script>
}
